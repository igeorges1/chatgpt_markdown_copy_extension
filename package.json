{
  "name": "chatgpt-markdown-copy-extension",
  "version": "2.0.0",
  "description": "Browser extension to copy ChatGPT and Gemini messages as Markdown",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint extension/**/*.js",
    "lint:fix": "eslint extension/**/*.js --fix",
    "lint:web-ext": "web-ext lint --source-dir=extension",
    "build": "tsup sentry10.32.1.ts --format iife --minify --sourcemap --outDir extension"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-plugin-mozilla": "^3.6.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "web-ext": "^7.11.0"
  },
  "keywords": [
    "chatgpt",
    "gemini",
    "markdown",
    "chrome-extension",
    "firefox-addon"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@sentry/browser": "^10.32.1"
  }
}
